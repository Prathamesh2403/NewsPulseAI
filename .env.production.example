# ─────────────────────────────────────────────────────────────────────────────
# .env.production.example
#
# Reference file showing ALL environment variables required in the Railway
# dashboard for each service. DO NOT put real values here — this file is
# documentation only and is safe to commit to git.
# ─────────────────────────────────────────────────────────────────────────────

# --- Database (Supabase) ---
DATABASE_URL=postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL_SYNC=postgresql+psycopg2://user:password@host:port/dbname

# --- Redis (provided automatically by Railway Redis addon) ---
REDIS_URL=redis://default:password@host:port/0

# --- ChromaDB (Railway volume mounted at this path) ---
CHROMADB_PATH=/app/data/vector_db

# --- LLM Providers ---
GEMINI_API_KEY=your_key
GEMINI_API_KEYS=key1,key2,key3
GEMINI_MODEL=gemini-2.5-flash

GROQ_API_KEY=your_key
GROQ_API_KEYS=key1,key2
GROQ_MODEL=llama-3.1-8b-instant

# --- News API Keys ---
NEWSDATA_API_KEY=your_key
NEWSDATA_API_KEYS=key1,key2,key3
NEWSAPI_KEY=your_key
APITUBE_API_KEY=your_key
GNEWS_API_KEY=your_key
TAVILY_API_KEY=your_key
TAVILY_API_KEYS=key1,key2

# --- Auth ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=your_bcrypt_hash_here   # generate with scripts/generate_password_hash.py
JWT_SECRET_KEY=your_random_64_char_secret   # generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_EXPIRY_HOURS=24

# --- CORS ---
FRONTEND_URL=https://your-app.vercel.app    # Set this to your actual Vercel deployment URL

# --- App ---
ENVIRONMENT=production
INGESTION_INTERVAL_HOURS=12
LOG_LEVEL=INFO
APP_ENV=production

# --- Embedding ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
