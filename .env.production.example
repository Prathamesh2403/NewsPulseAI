# =============================================================================
# RENDER PRODUCTION ENVIRONMENT VARIABLES
# =============================================================================
# Copy these into: Render Dashboard → your service → Environment
# Do NOT commit real values to git.
# =============================================================================

# --- App ---
ENVIRONMENT=production

# --- Database (Supabase Session Pooler — port 6543) ---
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:your_password@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres

# --- ChromaDB (Render persistent disk mount path) ---
CHROMADB_PATH=/opt/render/project/src/data/vector_db

# --- LLM providers ---
GEMINI_API_KEY=
GROQ_API_KEY=

# --- News APIs ---
NEWSDATA_API_KEY=
NEWSAPI_KEY=
TAVILY_API_KEY=
GNEWS_API_KEY=
APITUBE_API_KEY=

# --- Authentication ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=   # bcrypt hash — generate with:
                       # python -c "import bcrypt; print(bcrypt.hashpw(b'your_password', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD=        # plain password — used by cron job to call /auth/login

JWT_SECRET_KEY=        # generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_EXPIRY_HOURS=24

# --- CORS (fill after Vercel deploys) ---
FRONTEND_URL=https://your-app.vercel.app

# --- Redis (NOT needed in production — Celery is not used on Render) ---
# REDIS_URL=           # leave blank / do not set in production
